# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Anywork365

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL (via Prisma or Drizzle) — replace mock data when ready
DATABASE_URL=postgresql://user:password@localhost:5432/anywork365

# ─── AWS / Storage ────────────────────────────────────────────────────────────
# For profile image uploads (S3-compatible)
AWS_REGION=af-south-1
AWS_BUCKET_NAME=anywork365-uploads
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# ─── Payments (future) ────────────────────────────────────────────────────────
# Paystack (recommended for Nigeria)
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxx

# ─── Email (future) ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your-resend-api-key
EMAIL_FROM=noreply@anywork365.com

# ─── Demo Login ───────────────────────────────────────────────────────────────
DEMO_EMAIL=demo@anywork365.com
DEMO_PASSWORD=Demo1234
